{
  "name": "tee-time-hunter",
  "version": "1.0.0",
  "main": "bot.js",
  "type": "module",
  "scripts": {
     "postinstall": "playwright install chromium",
     "start": "node bot.js"
  },
  "dependencies": {
    "playwright": "^1.40.0",
    "node-fetch": "^3.3.2"
  }

  {
  "$schema": "https://railway.app/railway.schema.json",

  "build": {
    "builder": "NIXPACKS"
  },

  "deploy": {
    "startCommand": "node bot.js"
  },

  "nixpacks": {
    "phases": {
      "install": {
        "cmds": [
          "npm install",
          "npx playwright install chromium"
        ]
      }
    }
  }
}
}
